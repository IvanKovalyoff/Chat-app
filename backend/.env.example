DATABASE_URL="postgresql://postgres:postgres@localhost:5433/chat_app"

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN="10m"
JWT_REFRESH_EXPIRES_IN="30d"

PORT=3001
SERVER_URL="http://localhost:3001"
CLIENT_URL="http://localhost:5173"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Get an API key at https://resend.com - HTTP API, not SMTP, so it works
# on hosts like Railway that block outbound SMTP ports.
RESEND_API_KEY=
# Must be on a domain verified in your Resend account, e.g. no-reply@yourdomain.com.
# For testing without a verified domain, use onboarding@resend.dev (only delivers
# to the email address you signed up to Resend with).
EMAIL_FROM="no-reply@chat-app.dev"
